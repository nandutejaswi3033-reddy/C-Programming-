#include<stdio.h>
int main()
{
    int a = 20;
    int b = 50;
    
    int sum = a+b;
    int difference = a-b;
    int product = a*b;
    int quotient = a/b;
    int remainder = a%b;
    
    printf("sum:%d\n",sum);
    printf("difference:%d\n",difference);
    printf("product:%d\n",product);
    printf("quotient:%d\n",quotient);
    printf("remainder:%d\n",remainder);
    return 0;
}

